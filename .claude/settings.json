{
  "permissions": {
    "allow": [
      "mcp__github__list_branches",
      "mcp__github__get_file_contents"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/skill-usage.sh"
          }
        ]
      }
    ]
  }
}
